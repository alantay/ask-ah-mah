generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
}

model InventoryItem {
  id          String   @id @default(cuid())
  name        String
  type        String
  quantity    Int?
  unit        String?
  shelfLife   String   @default("medium")
  dateAdded   DateTime @default(now())
  lastUpdated DateTime @updatedAt
  userId      String

  @@map("inventory_items")
}

model Message{
    id          String   @id @default(cuid())
    userId      String
    content     String
    role        String
    createdAt   DateTime @default(now())

    @@map("messages")
    @@index([userId, createdAt])
}

model Recipe {
  id               String   @id @default(cuid())
  userId           String
  name             String
  instructions     String
  tags             String[]
  recipeId         String?
  baseServings     Int      @default(2)
  ingredients      Json     @default("[]")
  description      String?
  totalTimeMinutes Int?
  createdAt        DateTime @default(now())

  @@map("recipes")
  @@index([userId])
}